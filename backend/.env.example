# ============================================================
# BACKEND — Express.js (Render)
# ============================================================

# ── Database ────────────────────────────────────────────────
# Production: your Neon / Supabase / Railway Postgres URL
# Local:      prisma dev generates this automatically
DATABASE_URL="postgresql://user:password@host:5432/socialties?sslmode=require"

# ── Auth ────────────────────────────────────────────────────
# MUST match the AUTH_SECRET / NEXTAUTH_SECRET in the frontend .env
NEXTAUTH_SECRET="your-strong-random-secret-here"

# ── Admin Credentials (used by /api/auth/login) ─────────────
# ADMIN_EMAIL — the login email for the admin panel
ADMIN_EMAIL="admin@socialties.in"

# ADMIN_PASSWORD — (RECOMMENDED) plaintext admin password, hashed at startup
# This is the simplest option — just set it and deploy
ADMIN_PASSWORD="admin@socialties321!"

# ADMIN_PASSWORD_HASH — (ALTERNATIVE) pre-computed bcrypt hash
# Only used if ADMIN_PASSWORD is not set
# Generate with:  node -e "require('bcryptjs').hash('your-password', 12, (e,h)=>console.log(h))"
# ADMIN_PASSWORD_HASH="$2b$12$your_real_hash_here"

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Production: your Vercel URL
# Local:      http://localhost:3000
ALLOWED_ORIGINS="https://your-app.vercel.app,https://socialties.in"

# ── Port ────────────────────────────────────────────────────
# Render injects PORT automatically — only needed for local dev
BACKEND_PORT=4000
